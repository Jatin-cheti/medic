# Environment Variables Template
# Copy this file to .env and fill in your actual values

# Server Configuration
NODE_ENV=development
PORT=3000

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=medicdb
DATABASE_URL=mysql://root:your_mysql_password@localhost:3306/medicdb

# MongoDB
MONGO_URL=mongodb://localhost:27017/medicdb

# JWT Configuration (IMPORTANT: Generate strong random secrets for production)
# Use: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=generate_a_strong_random_secret_min_32_characters
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=generate_a_different_strong_random_secret_min_32_characters
JWT_REFRESH_EXPIRES_IN=7d

# Frontend Configuration
FRONTEND_ORIGIN=http://localhost:4200
CORS_ORIGINS=http://localhost:4200,http://127.0.0.1:4200

# Google OAuth (Optional - only if using Google authentication)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# Redis (Optional - for caching and sessions)
REDIS_HOST=localhost
REDIS_PORT=6379

# Email Configuration (Optional - for notifications)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASS=your_email_password

# File Upload Configuration
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=jpg,jpeg,png,pdf

# Security
BCRYPT_ROUNDS=10
SESSION_SECRET=generate_a_strong_random_session_secret
