# Production environment variables
# Copy this to .env.production and fill in your actual production values

# JWT Secrets (generate strong random strings for production)
JWT_SECRET=your_production_jwt_secret_min_32_characters_long
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=your_production_refresh_secret_min_32_characters_long
JWT_REFRESH_EXPIRES_IN=7d

# Production MySQL Database (e.g., PlanetScale, AWS RDS, etc.)
DATABASE_URL=mysql://username:password@host:port/database

# Production MongoDB (e.g., MongoDB Atlas)
MONGO_URL=mongodb+srv://username:password@cluster.mongodb.net/database

# Production Redis (e.g., Upstash, Redis Labs)
REDIS_URL=redis://username:password@host:port

# Frontend Origin (your deployed Angular app URL)
FRONTEND_ORIGIN=https://your-frontend-app.vercel.app

# Optional: Google OAuth Credentials
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=https://your-backend-app.vercel.app/api/auth/google/callback
