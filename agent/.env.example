# DevMedic Agent – Environment Variables
# Copy this file to .env and fill in your values

# ─── Required ───────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ─── Optional – Figma integration ───────────────────────────
FIGMA_API_TOKEN=
FIGMA_FILE_KEY=

# ─── Optional – Deployment ──────────────────────────────────
VERCEL_TOKEN=
RAILWAY_TOKEN=

# ─── Optional – Git ─────────────────────────────────────────
GIT_REMOTE_URL=
GIT_BRANCH=main

# ─── Agent tuning ───────────────────────────────────────────
# AI model to use (default: gpt-4o)
AGENT_MODEL=gpt-4o
# Max tokens per AI response
AGENT_MAX_TOKENS=4096
# How many times to retry failing tests automatically
AGENT_MAX_TEST_RETRIES=3
# Root of the medic project (defaults to parent of agent/)
PROJECT_ROOT=
